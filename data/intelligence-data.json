  "clarifications": {
    "items": [
      {
        "id": "CL001",
        "title": "Gratuity in CTC",
        "status": "resolved",
        "priority": "high",
        "question": "Can gratuity be shown in CTC?",
        "answer": "NO. Gratuity is a statutory liability, not a salary component. Cannot be part of CTC.",
        "sources": [
          { "name": "ICAI FAQ", "type": "regulatory", "date": "2025-12-28", "url": "https://icai.org/" },
          { "name": "MoLE Clarification", "type": "government", "date": "2026-01-10", "url": "https://labour.gov.in/" }
        ],
        "axionView": { "recommendation": "Remove from CTC; show separately. Get actuarial valuation.", "actionTag": "act" },
        "actionItems": ["Remove from offer letters", "Get actuarial valuation", "Update payroll systems"],
        "lastVerified": "2026-04-12"
      },
      {
        "id": "CL002",
        "title": "Leave Encashment in Gratuity Calculation",
        "status": "partial",
        "priority": "high",
        "question": "Should leave encashment be included in gratuity calculation?",
        "answer": "Partial resolution. Leave encashment at termination is separate from gratuity but may impact gratuity if paid during service.",
